### This is the only variable needed the first time you
### run the docker postgres container
POSTGRES_PASSWORD=''

### Optional superuser name. Defaults to `postgres`.
POSTGRES_USER='postgres'

### Optional database created on first startup. Defaults to POSTGRES_USER.
POSTGRES_DB='postgres'

### Optional: absolute path or command name for psql client used by _psql_connect.
### If blank, the script will use `psql` from PATH.
POSTGRES_CLIENT=''

### PostgreSQL listen_addresses. Defaults to 127.0.0.1 (localhost only).
###
### Network access notes:
### - If you want to connect from containers on the same linux machine,
###   include the docker bridge interface (often 172.17.0.1)
### - If you want external network access, include a network-reachable host interface
POSTGRES_LISTEN_ADDRESSES='127.0.0.1'

### Optional host/port defaults for _psql_connect
POSTGRES_HOST='localhost'
POSTGRES_PORT='5432'
