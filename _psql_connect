#!/bin/bash
#
# Quick connect to the docker postgresql instance

set -euo pipefail

# Preserve caller-provided values so sourcing .env does not override them.
PRESERVE_VARS=(
    APP_DB_USER
    APP_DB_PASSWORD
    APP_DB_NAME
    POSTGRES_HOST
    POSTGRES_PORT
)

for _var in "${PRESERVE_VARS[@]}"; do
    if [[ -n "${!_var+x}" ]]; then
        export "__PRESERVE_${_var}=${!_var}"
        export "__HAS_PRESERVE_${_var}=1"
    fi
done

if [[ -f .env ]]; then
    set -a
    source .env
    set +a
fi

for _var in "${PRESERVE_VARS[@]}"; do
    _flag="__HAS_PRESERVE_${_var}"
    if [[ -n "${!_flag:-}" ]]; then
        _saved="__PRESERVE_${_var}"
        printf -v "$_var" '%s' "${!_saved}"
        export "$_var"
        unset "$_flag" "$_saved"
    fi
done

USER="${APP_DB_USER:-}"
USER_PASSWORD="${APP_DB_PASSWORD:-}"
DATABASE="${APP_DB_NAME:-}"
HOST="${POSTGRES_HOST:-localhost}"
PORT="${POSTGRES_PORT:-5432}"
CONNECT_TIMEOUT="5"

if [[ -z "$USER" || -z "$USER_PASSWORD" || -z "$DATABASE" ]]; then
    echo "Error: APP_DB_USER, APP_DB_PASSWORD, and APP_DB_NAME must be set (in .env or inline env)." >&2
    exit 1
fi

if ! command -v psql >/dev/null 2>&1; then
    echo "Error: psql client not found in PATH. Install PostgreSQL client tools." >&2
    exit 1
fi
PSQL_CLIENT_CMD="$(command -v psql)"

echo "Connecting with user: $USER"
echo "Connecting to db: $DATABASE"
echo "Connecting to host: $HOST:$PORT (timeout=${CONNECT_TIMEOUT}s)"
echo "Using psql client: $PSQL_CLIENT_CMD"
sleep 1

PGPASSWORD="$USER_PASSWORD" PGCONNECT_TIMEOUT="$CONNECT_TIMEOUT" "$PSQL_CLIENT_CMD" \
    --host="$HOST" \
    --port="$PORT" \
    --username="$USER" \
    --dbname="$DATABASE"
